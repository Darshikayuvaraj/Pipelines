    <processType>AutoLaunchedFlow</processType>
    <sourceTemplate>eduadvncdacad__RunRgstrTmlnApplnJob</sourceTemplate>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>SetBatchJobStatuses</targetReference>
        </connector>
        <flowRunAsUser>TriggeringUser</flowRunAsUser>
        <object>AcadRgstrApplnEvent</object>
